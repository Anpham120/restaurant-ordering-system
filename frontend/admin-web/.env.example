# =============================================================================
# TV FOOD – Admin Web (frontend/admin-web) – Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in values for your environment.
# .env.local is git-ignored and will NOT be committed.
#
# Usage:
#   cp .env.example .env.local
#   # then edit .env.local with your actual values
# =============================================================================

# ── Backend API base URL ──────────────────────────────────────────────────────
# Base URL of the restaurant-api (WITHOUT /api/v1 suffix).
# Used by the app for REST calls AND for deriving the SignalR hub URL.
#
# Local dev (dotnet run default):
VITE_API_BASE_URL=https://localhost:5001

# ── SignalR Hub URL (optional) ────────────────────────────────────────────────
# If set, the app connects to this exact URL for SignalR.
# If NOT set, the hub URL is auto-derived from VITE_API_BASE_URL:
#   <VITE_API_BASE_URL>/hubs/restaurant
#
# Only set this if your hub is at a different host/port than the REST API.
# VITE_RESTAURANT_HUB_URL=wss://realtime.myapp.com/hubs/restaurant
