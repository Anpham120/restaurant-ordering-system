# =============================================================================
# Restaurant Ordering System – Customer Web – Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in values for your environment.
# .env.local is git-ignored and will NOT be committed.
#
# Usage:
#   cp .env.example .env.local

# ── Backend API base URL ──────────────────────────────────────────────────────
# Local dev (dotnet run http profile):
VITE_API_BASE_URL=http://localhost:5030
# Local dev (dotnet run https profile): VITE_API_BASE_URL=https://localhost:7169
# Docker compose: VITE_API_BASE_URL=http://localhost:5000

# ── AI Service base URL ────────────────────────────────────────────────────────
# FastAPI AI service used by the customer assistant.
VITE_AI_BASE_URL=http://localhost:8000
